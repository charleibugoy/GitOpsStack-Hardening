#!/bin/bash
# AWS CloudShell DevOps Tools Installer
# Binaries installed to /bin (as requested)

set -e

echo "=== Updating system packages ==="
sudo yum update -y

echo "=== Installing prerequisites ==="
sudo yum install -y curl wget unzip tar python3 python3-pip

echo "=== Ensuring /bin is writable with sudo ==="
sudo chmod -R 755 /bin 2>/dev/null || true

# ============================
# 1. kubectl
# ============================
echo "=== Installing kubectl ==="
curl -LO "https://k8s.io(curl -L -s https://k8s.io)/bin/linux/amd64/kubectl"

# 2. Make the binary executable
chmod +x kubectl

# 3. Move it to your persistent local directory
mkdir -p ~/.local/bin
mv kubectl ~/.local/bin/

# 4. Ensure ~/.local/bin is in your PATH
if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
    echo 'export PATH="$HOME/.local/bin:$PATH"' >> ~/.bashrc
    export PATH="$HOME/.local/bin:$PATH"
fi

# 5. Reload your shell and verify
source ~/.bashrc
echo "kubectl: $(kubectl version --client --short 2>/dev/null || echo 'installed')"

# ============================
# 2. Helm
# ============================
echo "=== Installing Helm ==="
curl https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash
echo "Helm: $(helm version --short 2>/dev/null || echo 'installed')"

# ============================
# 3. ArgoCD CLI
# ============================
echo "=== Installing ArgoCD CLI ==="
curl -sSL -o /tmp/argocd https://github.com/argoproj/argo-cd/releases/latest/download/argocd-linux-amd64

# Move binary to the local user directory (doesn't require root/sudo)
mkdir -p ~/.local/bin
mv /tmp/argocd ~/.local/bin/argocd

# Make it executable
chmod +x ~/.local/bin/argocd

# Ensure ~/.local/bin is in your PATH
if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
    echo 'export PATH="$HOME/.local/bin:$PATH"' >> ~/.bashrc
    export PATH="$HOME/.local/bin:$PATH"
    echo "Added ~/.local/bin to your PATH in ~/.bashrc"
fi

echo "Verifying installation..."
echo "ArgoCD: $(argocd version --client --short 2>/dev/null || echo 'installed')"

# ============================
# 4. Ansible
# ============================
echo "=== Installing Ansible ==="
pip3 install ansible
echpip3 install ansibleo "Ansible: $(ansible --version | head -n 1)"

# ============================
# 5. Trivy
# ============================
echo "=== Installing Trivy ==="
curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh -s -- -b ~/bin
echo "Trivy: $(Trivy --version 2>/dev/null || echo 'installed')"

# ============================
# 6. Terraform
# ============================
echo "=== Installing Terraform ==="
git clone https://github.com/tfutils/tfenv.git ~/.tfenv
mkdir -p ~/bin
ln -s ~/.tfenv/bin/* ~/bin/
tfenv install 1.5.7
tfenv use 1.5.7
echo "Terraform: $(terraform version 2>/dev/null || echo 'installed')"

# ============================
# 7. Lula CLI
# ============================
echo "=== Installing Lula CLI ==="
curl -sSfL https://github.com/defenseunicorns/lula/releases/latest/download/lula_Linux_x86_64.tar.gz | tar -xz
chmod +x lula
sudo mv lula /bin/
echo "Lula: $(lula version 2>/dev/null || echo 'installed')"

# ============================
# 8. Kyverno CLI
# ============================
echo "=== Installing Kyverno CLI ==="
curl -LO https://github.com/kyverno/kyverno/releases/latest/download/kyverno-cli_linux_amd64.tar.gz
tar -xzf kyverno-cli_linux_amd64.tar.gz
chmod +x kyverno
sudo mv kyverno /bin/
rm -f kyverno-cli_linux_amd64.tar.gz
echo "Kyverno: $(kyverno version 2>/dev/null || echo 'installed')"

echo ""
echo "========================================"
echo "✅ Installation Completed!"
echo "========================================"
echo "All tools installed to /bin"
echo ""
echo "Verification commands:"
echo "  kubectl version --client"
echo "  helm version"
echo "  argocd version --client"
echo "  ansible --version"
echo "  trivy --version"
echo "  terraform version"
echo "  lula version"
echo "  kyverno version"